# Example local.properties for development (DO NOT COMMIT real secrets)
# Add this file to understand required entries; copy to android/local.properties

# Flutter SDK path is set by users; example below is placeholder:
# flutter.sdk=C:\\path\\to\\flutter

# Add your Mapbox downloads token here (used for Mapbox Maven repository access):
MAPBOX_DOWNLOADS_TOKEN=your-mapbox-downloads-token

# Provide the runtime Mapbox access token at build time, for example:
# flutter run --dart-define=MAPBOX_ACCESS_TOKEN=your-mapbox-access-token
