# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
/backend/node_modules/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/android/app/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Local Android and backend secrets
/android/local.properties
/backend/.env
/backend/serviceAccountKey.json
/.env
/.env.local
/.env.*.local

# Local build artifacts & large binaries (avoid committing caches, zips, native libs)
# Gradle wrapper distributions and local gradle caches
android/.gradle-home/
.gradle-home/

# Generated native libraries, heap dumps and java profiler files
*.hprof
java_pid*.hprof

# Flutter / build outputs (already covered above, kept for clarity)
build/
**/build/

# Android packaging artifacts
*.apk
*.aab

# If you want to store big binaries, consider using Git LFS instead

# Additional large files to ignore (gradle caches, wrapper dists, build artifacts)
# Top-level and android-specific gradle home/cache directories
.gradle-home/
android/.gradle-home/
.gradle/
android/.gradle/

# Gradle wrapper distributions and caches
**/wrapper/dists/
**/caches/

# Archive and binary blobs produced by Gradle or profiling tools
*.zip
*.jar
*.hprof

